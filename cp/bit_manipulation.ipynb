   "source": [
    "#Number of 1 Bits\n",
    "from collections import Counter\n",
    "class Solution:\n",
    "    def hammingWeight(self, n: int) -> int:\n",
    "        h = []\n",
    "        while n >= 1:\n",
    "            h.append(n%2)\n",
    "            n = n//2\n",
    "        counted = Counter(h)\n",
    "        return counted[1]\n"
   ]
  }
